#!/usr/bin/env bash
# gpt-image skill 的便捷入口（bash 包装）
#
# 用法：gpt-image generate --prompt "..." --preset ppt_cover_169
#       gpt-image edit --image a.png --mask a_mask.png --prompt "..."
#       gpt-image history --last 5
#       gpt-image preset
#
# 环境变量：AI_API_BASE_URL / AI_API_KEY / AI_MODEL

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# 加载 ~/.zshrc 或 ~/.bash_profile 中已 export 的环境变量（如果当前 shell 没有）
# 这里不强制 source，避免在子 shell 里污染。

exec python3 "${SKILL_DIR}/lib/client.py" --workspace "${SKILL_DIR}/workspace" "$@"
